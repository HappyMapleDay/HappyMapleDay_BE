# ===============================================
# 개발 환경 설정 템플릿 (참고용)
# ===============================================
# 이 파일은 로컬 개발 시 필요한 환경변수 템플릿입니다.
# 사용 방법:
#   1. 이 파일을 복사: cp env/dev.env.example env/dev.env
#   2. env/dev.env 파일에서 실제 값으로 수정
#   3. docker-compose --env-file env/dev.env up
# ===============================================

# 공통 DB 설정
DB_HOST=172.16.2.136
DB_PORT=3306
DB_NAME_PREFIX=happy_maple_day_dev_
DB_USERNAME=appuser

# 서비스별 DB 비밀번호 (실제 값으로 변경 필요)
BOSS_DB_PASSWORD=<your-password-here>
USER_DB_PASSWORD=<your-password-here>
CHAR_DB_PASSWORD=<your-password-here>
SETTLE_DB_PASSWORD=<your-password-here>
ADMIN_DB_PASSWORD=<your-password-here>

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Spring Profile
SPRING_PROFILES_ACTIVE=dev

# OCI Object Storage
OCI_NAMESPACE=<your-oci-namespace>
OCI_BUCKET_NAME=<your-bucket-name>
OCI_REGION=<your-region>
OCI_FOLDER_PREFIX=dev
OCI_USER_OCID=<your-user-ocid>
OCI_TENANCY_OCID=<your-tenancy-ocid>
OCI_FINGERPRINT=<your-api-key-fingerprint>
OCI_PRIVATE_KEY_PATH=/path/to/your/private-key.pem

