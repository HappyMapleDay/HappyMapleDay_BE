# DB(MySQL)
DB_HOST=your-db-endpoint
DB_PORT=3306

# Redis (ElastiCache 등)
REDIS_HOST=your-redis-endpoint.cache.amazonaws.com
REDIS_PORT=6379

# 서비스별 DB 계정 (운영 비밀번호 채움)
BOSS_DB_USER=boss_user
BOSS_DB_PASSWORD=
CHAR_DB_USER=character_user
CHAR_DB_PASSWORD=
SETTLE_DB_USER=settlement_user
SETTLE_DB_PASSWORD=
HISTORY_DB_USER=history_user
HISTORY_DB_PASSWORD=
ADMIN_DB_USER=admin_user
ADMIN_DB_PASSWORD=

# 태그(이미지 버전)
TAG=latest


