# ===============================================
# 운영 환경 설정 템플릿 (참고용)
# ===============================================
# 이 파일은 운영 배포 시 필요한 환경변수 템플릿입니다.
# 실제 배포는 GitHub Secrets에서 환경변수를 동적으로 생성합니다.
# 로컬에서 운영 환경 테스트 시:
#   1. 이 파일을 복사: cp env/prod.env.example env/prod.env
#   2. env/prod.env 파일에서 실제 운영 값으로 수정
#   3. docker-compose --env-file env/prod.env up
# ===============================================

# 공통 DB 설정
DB_HOST=<your-production-db-endpoint>
DB_PORT=3306
DB_NAME_PREFIX=happy_maple_day_
DB_USERNAME=appuser

# 서비스별 DB 비밀번호 (실제 운영 비밀번호로 변경 필요)
BOSS_DB_PASSWORD=<your-secure-password>
USER_DB_PASSWORD=<your-secure-password>
CHAR_DB_PASSWORD=<your-secure-password>
SETTLE_DB_PASSWORD=<your-secure-password>
ADMIN_DB_PASSWORD=<your-secure-password>

# Redis
REDIS_HOST=<your-redis-endpoint>
REDIS_PORT=6379

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# 태그(이미지 버전)
TAG=latest

